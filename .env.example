# API keys for LLMAgent integration tests + dogfood runs (and the
# multi-LLM demo generators under web/scripts/). DO NOT commit your
# real keys — this file is the example template; copy to .env locally.
#
# All seven providers we currently support live in
# src/llm_poker_arena/agents/llm/providers/registry.py. Adding a new
# entry there auto-extends the CLI / generator support, but you still
# need to add the matching env var below.

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...
# Set to "1" to enable the gated integration test that hits the real
# Anthropic API. Default: skipped.
ANTHROPIC_INTEGRATION_TEST=

# --- DeepSeek (OpenAI-compatible at base_url=https://api.deepseek.com/v1) ---
DEEPSEEK_API_KEY=
# Set to "1" to enable the gated integration test that hits the real
# DeepSeek API. Default: skipped.
DEEPSEEK_INTEGRATION_TEST=

# --- OpenAI (canonical Chat Completions API) ---
OPENAI_API_KEY=

# --- Alibaba Qwen (DashScope) ---
QWEN_API_KEY=

# --- Moonshot Kimi ---
# IMPORTANT: this codebase points at the .cn (China-region) endpoint
# (api.moonshot.cn). If your key is for the international .ai endpoint,
# edit registry.py to swap the base_url locally — do NOT push the swap.
KIMI_API_KEY=

# --- Google Gemini (AI Studio, OpenAI-compat shim) ---
GEMINI_API_KEY=

# --- xAI Grok (optional, for experiments) ---
GROK_API_KEY=

# --- OpenRouter (multi-vendor gateway, optional) ---
# Used to access models that aren't available on their native provider's
# OpenAI-compat endpoint — currently gemini-3.1-pro-preview (Vertex AI
# only on the native side, but available via OpenRouter without GCP
# setup). Sign up at https://openrouter.ai for an API key.
OPENROUTER_API_KEY=
